npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next-start*.log
local-start.log
.logs/
.tmp-owner-token.txt
wmic_test.txt

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# local editor/workspace state
.vscode/

# local agent/skill state
.agents/
skills-lock.json

