    "repair:supabase:bank-ledgers": "node scripts/repair-supabase-bank-ledgers.mjs",
    "reseed:supabase:safe-workflow": "npm run reset:supabase -- --all-managed-data --preserve-users --preserve-trip-rates && npm run ensure:supabase:trip-rates && npm run seed:supabase:safe-workflow && npm run repair:supabase:bank-ledgers && npm run backfill:accounting",
    "reseed:supabase:trip-surat-jalan": "npm run reset:supabase && npm run seed:supabase:trip-surat-jalan"
