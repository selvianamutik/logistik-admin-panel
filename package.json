    "audit:settings-document-format": "npx tsx scripts/audit-settings-document-format.ts",
    "audit:password-hashes": "node scripts/audit-password-hashes.mjs",
    "audit:accounting-integrity": "npx tsx --conditions react-server scripts/audit-accounting-integrity.ts",
    "audit:finance-integrity": "npx tsx --conditions react-server scripts/audit-finance-integrity.ts",
    "audit:mobile-driver-manifest-flow": "node scripts/audit-mobile-driver-manifest-flow.mjs",
    "audit:order-item-auto-weight": "npx tsx scripts/audit-order-item-auto-weight.ts",
