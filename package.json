{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next build --webpack",
    "build:turbopack": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "npx next typegen && tsc --noEmit",
    "audit:finance": "node scripts/audit-finance.mjs",
    "reset:sanity": "npx tsx scripts/reset-sanity.ts",
    "seed:sanity": "npx tsx scripts/seed-sanity.ts",
    "reseed:sanity": "npm run reset:sanity && npm run seed:sanity"
  },
  "dependencies": {
    "@sanity/client": "^7.16.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "jose": "^6.1.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5"
  }
}
