    "audit:supabase": "node scripts/audit-supabase-migration.mjs",
    "backfill:accounting": "npx tsx --conditions react-server scripts/backfill-accounting-journals.ts",
    "backfill:trip-surat-jalan": "node scripts/backfill-trip-surat-jalan.mjs",
    "convert:seed:trip-surat-jalan": "node scripts/convert-seed-to-trip-surat-jalan.mjs",
    "verify:seed:trip-surat-jalan": "node scripts/verify-seed-trip-surat-jalan.mjs",
    "import:supabase": "node scripts/import-supabase.mjs",
    "reset:supabase": "node scripts/reset-supabase.mjs",
